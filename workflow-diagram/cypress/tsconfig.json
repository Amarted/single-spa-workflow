{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [
      "cypress",
      "@cypress/react"
    ],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "paths": {
      "@shared/*": [
        "../root-config/src/shared/*"
      ]
    }
  },
  "include": [
    "../cypress.config.ts",
    "./**/*.ts",
    "./**/*.tsx",
    "../src/**/*.ts",
    "../src/**/*.tsx"
  ]
}